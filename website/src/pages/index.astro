---
import SocialIcons from '../components/SocialIcons.astro';
import ThemeProvider from '../components/ThemeProvider.astro';
import barsIcon from '@hackernoon/pixel-icon-library/icons/SVG/regular/bars.svg?raw';
import timesIcon from '@hackernoon/pixel-icon-library/icons/SVG/regular/times.svg?raw';
import rustIcon from '../icons/rust.svg?raw';
import goIcon from '../icons/go.svg?raw';
import javaIcon from '../icons/openjdk.svg?raw';
import nodeIcon from '../icons/nodedotjs.svg?raw';
import pythonIcon from '../icons/python.svg?raw';
import apacheIcon from '../icons/apache.svg?raw';
import awsIcon from '../icons/amazonwebservices.svg?raw';
import cloudflareIcon from '../icons/cloudflare.svg?raw';
import gcpIcon from '../icons/googlecloud.svg?raw';
import { getStarsLabel } from '../lib/github-stars';
import { highlight } from '../lib/highlight';
import Analytics from '../components/Analytics.astro';

const starsLabel = await getStarsLabel();

const site = 'https://slatedb.io';
// Single source of truth for the homepage description. Reused verbatim across
// <meta name="description">, og:description, twitter:description, and the
// JSON-LD `description` so agents that cross-check these sources see one
// consistent summary.
const metaDescription =
    'SlateDB is an open-source embedded key-value database, implemented as an LSM tree, that depends on object storage alone for durability.';
const pageTitle = 'SlateDB — An embedded database built on object storage';
const ogImage = `${site}/img/slatedb-opengraph.jpg`;

// Structured data (schema.org / JSON-LD). Describes SlateDB as an open-source
// developer library so AI agents and search engines can identify the entity,
// link it to authoritative profiles (sameAs), and answer questions about it.
const jsonLd = {
    '@context': 'https://schema.org',
    '@graph': [
        {
            '@type': 'Organization',
            '@id': `${site}/#organization`,
            name: 'SlateDB',
            url: site,
            logo: `${site}/img/logo-full.svg`,
            description: metaDescription,
            sameAs: [
                'https://github.com/slatedb/slatedb',
                'https://crates.io/crates/slatedb',
                'https://docs.rs/slatedb',
                'https://discord.gg/mHYmGy5MgA',
            ],
        },
        {
            '@type': 'WebSite',
            '@id': `${site}/#website`,
            url: site,
            name: 'SlateDB',
            description: metaDescription,
            publisher: { '@id': `${site}/#organization` },
            inLanguage: 'en',
        },
        {
            '@type': 'WebPage',
            '@id': `${site}/#webpage`,
            url: `${site}/`,
            name: pageTitle,
            description: metaDescription,
            isPartOf: { '@id': `${site}/#website` },
            about: { '@id': `${site}/#software` },
            inLanguage: 'en',
            // Tell voice/agent readers which text best summarizes the page.
            speakable: {
                '@type': 'SpeakableSpecification',
                cssSelector: ['.hero-headline', '.hero-sub'],
            },
        },
        {
            '@type': ['SoftwareApplication', 'SoftwareSourceCode'],
            '@id': `${site}/#software`,
            name: 'SlateDB',
            applicationCategory: 'DeveloperApplication',
            operatingSystem: 'Cross-platform',
            description: metaDescription,
            url: site,
            codeRepository: 'https://github.com/slatedb/slatedb',
            programmingLanguage: ['Rust', 'Go', 'Java', 'Python', 'JavaScript'],
            license: 'https://github.com/slatedb/slatedb/blob/main/LICENSE',
            isAccessibleForFree: true,
            offers: {
                '@type': 'Offer',
                price: '0',
                priceCurrency: 'USD',
            },
            keywords:
                'embedded database, key-value store, LSM engine, object storage, S3, GCS, Azure Blob Storage, Rust, storage engine',
            author: { '@id': `${site}/#organization` },
            sameAs: [
                'https://github.com/slatedb/slatedb',
                'https://crates.io/crates/slatedb',
                'https://docs.rs/slatedb',
            ],
        },
    ],
};

// The "used by" companies — even row, all logos rendered at the same height.
const usedBy = [
    { name: 'Dropbox',    href: 'https://www.dropbox.com/',     logo: '/img/logos/dropbox.svg',    scale: 1.2 },
    { name: 'HelixDB',    href: 'https://www.helix-db.com/',      logo: '/img/logos/helixdb.png',    scale: 0.8 },
    { name: 'TensorLake', href: 'https://www.tensorlake.ai/',   logo: '/img/logos/tensorlake.svg', scale: 1.2 },
    { name: 'S2',         href: 'https://s2.dev/',                logo: '/img/logos/s2.svg' },
    { name: 'Goldsky',    href: 'https://goldsky.com/',           logo: '/img/logos/goldsky.svg' },
    { name: 'Gadget',     href: 'https://gadget.dev/',            logo: '/img/logos/gadget.svg' },
    { name: 'MerkleMap',  href: 'https://merklemap.com/',        logo: '/img/logos/merklemap.svg' },
    { name: 'OpenData',   href: 'https://opendata.dev/',         logo: '/img/logos/opendata.svg' },
    { name: 'Massive',    href: 'https://massive.com/',           logo: '/img/logos/massive.png' },
];

// Quickstart language entries.
const langs = [
    {
        id: 'rust',
        label: 'rust',
        install: 'cargo add slatedb tokio --features tokio/macros,tokio/rt-multi-thread',
        code: `use slatedb::Db;
use slatedb::object_store::memory::InMemory;

let store = std::sync::Arc::new(InMemory::new());
let db = Db::builder("demo", store).build().await?;

db.put(b"hello", b"world").await?;
let value = db.get(b"hello").await?;`,
    },
    {
        id: 'go',
        label: 'go',
        install: 'go get slatedb.io/slatedb-go',
        code: `store, _ := slatedb.ObjectStoreResolve("memory:///")
builder := slatedb.NewDbBuilder("demo", store)
db, _ := builder.Build()

db.Put([]byte("hello"), []byte("world"))
value, _ := db.Get([]byte("hello"))`,
    },
    {
        id: 'java',
        label: 'java',
        install: "implementation 'io.slatedb:slatedb-uniffi'",
        code: `ObjectStore store = ObjectStore.resolve("memory:///");
DbBuilder builder = new DbBuilder("demo", store);
Db db = builder.build().get();

db.put("hello".getBytes(), "world".getBytes()).get();
byte[] value = db.get("hello".getBytes()).get();`,
    },
    {
        id: 'node',
        label: 'node',
        install: 'npm install @slatedb/uniffi',
        code: `const store = ObjectStore.resolve("memory:///");
const builder = new DbBuilder("demo", store);
const db = await builder.build();

await db.put(Buffer.from("hello"), Buffer.from("world"));
const value = await db.get(Buffer.from("hello"));`,
    },
    {
        id: 'python',
        label: 'python',
        install: 'pip install slatedb',
        code: `store = ObjectStore.resolve("memory:///")
builder = DbBuilder("demo", store)
db = await builder.build()

await db.put(b"hello", b"world")
value = await db.get(b"hello")`,
    },
];

// Four mechanism-named feature cells for the homepage engineering plate.
const features = [
    {
        id: 'zero-disk',
        figure: 'Fig. 1',
        figureTitle: 'object storage native design',
        name: 'Zero-disk architecture',
        body: 'Persist data directly to object storage. Keep 99.999999999% durability and cost profile of S3-class storage without local disks or cross-AZ storage traffic.',
        figureImg: '/img/feature-zero-disk.png',
        figureScaled: true,
        href: '/docs/design/overview/',
    },
    {
        id: 'deployment',
        figure: 'Fig. 2',
        figureTitle: 'single-writer, multi-reader',
        name: 'Flexible deployment',
        body: 'SlateDB ensures a single writer through a formally verified manifest fencing protocol but supports multiple readers for read-side scaling. Compaction can run embedded or as a separate process to enforce separation of concerns.',
        figureImg: '/img/feature-deployment.png',
        href: '/docs/design/readers/',
    },
    {
        id: 'semantics',
        figure: 'Fig. 3',
        figureTitle: 'suitable for OLTP workloads',
        name: 'Transactional semantics',
        body: 'Transactions, snapshots, and optimistic concurrency control mechanisms ensure that SlateDB is suitable for the most demanding transactional workloads.',
        figureImg: '/img/feature-semantics.png',
        href: '/docs/design/consistency/',
    },
    {
        id: 'performance',
        figure: 'Fig. 4',
        figureTitle: 'latency and cost controls',
        name: 'Tunable performance',
        body: 'Writes can trade between API request cost and durability latency while reads can leverage hybrid memory/disk caching to avoid cold latency penalties.',
        figureImg: '/img/feature-performance.png',
        href: '/docs/operations/tuning/',
    },
    {
        id: 'clones',
        figure: 'Fig. 5',
        figureTitle: 'zero-copy operations',
        name: 'Clones, branches & rescaling',
        body: 'Checkpointing is a zero-copy operation and functions as the basis for a clone or fork. Rescaling is also zero-copy, enabling <code>O(1)</code> splits and merges of Slates.',
        figureImg: '/img/feature-clones.png',
        href: '/docs/design/clones/',
    },
];

// Three linked property cells beneath the editorial lead. Each is a docs/repo
// link fronted by a row of brand glyphs (inlined SVG, tinted via currentColor).
const osLinks = [
    {
        id: 'clients',
        kicker: 'clients',
        href: '/docs/get-started/quickstart/',
        desc: 'Rust core with Go, Java, Node & Python bindings.',
        icons: [
            { label: 'Rust', svg: rustIcon },
            { label: 'Go', svg: goIcon },
            { label: 'Java', svg: javaIcon },
            { label: 'Node', svg: nodeIcon },
            { label: 'Python', svg: pythonIcon },
        ],
    },
    {
        id: 'object-storage',
        kicker: 'object storage',
        href: '/docs/operations/configuration/',
        desc: 'Runs on S3, R2, GCS & most object stores.',
        icons: [
            { label: 'Amazon S3', svg: awsIcon },
            { label: 'Cloudflare R2', svg: cloudflareIcon },
            { label: 'Google Cloud Storage', svg: gcpIcon },
        ],
    },
    {
        id: 'license',
        kicker: 'license',
        href: 'https://github.com/slatedb/slatedb/blob/main/LICENSE',
        external: true,
        desc: 'Apache 2.0 free and open source.',
        icons: [
            { label: 'Apache 2.0', svg: apacheIcon },
        ],
    },
];
---

<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>{pageTitle}</title>
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="canonical" href={`${site}/`} />
        <meta name="description" content={metaDescription} />
        <link rel="alternate" type="text/markdown" href="/index.md" title="Markdown source" />
        <!-- Open Graph -->
        <meta property="og:type" content="website" />
        <meta property="og:site_name" content="SlateDB" />
        <meta property="og:title" content={pageTitle} />
        <meta property="og:description" content={metaDescription} />
        <meta property="og:url" content={`${site}/`} />
        <meta property="og:image" content={ogImage} />
        <meta property="og:image:alt" content="SlateDB | An embedded database built on object storage" />
        <!-- Twitter -->
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={pageTitle} />
        <meta name="twitter:description" content={metaDescription} />
        <meta name="twitter:image" content={ogImage} />
        <!-- Structured data -->
        <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            rel="stylesheet"
            href="https://fonts.googleapis.com/css2?family=Marcellus&family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,500;0,8..60,600;0,8..60,700;1,8..60,400;1,8..60,500;1,8..60,600;1,8..60,700&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
        />
        <Analytics />
    </head>
    <body>
        <ThemeProvider />
        <div class="page">
            <header class="header">
                <div class="header-content">
                    <a href="/" class="site-title">
                        <img src="/img/logo-full.svg" alt="SlateDB" />
                    </a>
                    <div class="right-group">
                        <nav class="header-links">
                            <a href="/docs/get-started/introduction/" class="header-link">docs</a>
                            <a href="/blog/" class="header-link">blog</a>
                            <a href="https://discord.gg/mHYmGy5MgA" target="_blank" rel="noopener noreferrer" class="header-link">discord</a>
                            <a href="https://github.com/slatedb/slatedb" target="_blank" rel="noopener noreferrer" class="header-link" id="github-link">github <span class="star-count"><span class="star-icon">★</span>{starsLabel}</span></a>
                        </nav>
                        <button class="mobile-menu-toggle" id="mobile-menu-toggle" aria-label="Toggle menu" aria-expanded="false">
                            <span class="menu-icon menu-icon-bars" set:html={barsIcon}></span>
                            <span class="menu-icon menu-icon-times" set:html={timesIcon}></span>
                        </button>
                    </div>
                    <div class="mobile-menu" id="mobile-menu">
                        <a href="/docs/get-started/introduction/" class="mobile-menu-link">docs</a>
                        <a href="/blog/" class="mobile-menu-link">blog</a>
                        <a href="https://discord.gg/mHYmGy5MgA" target="_blank" rel="noopener noreferrer" class="mobile-menu-link">discord</a>
                        <a href="https://github.com/slatedb/slatedb" target="_blank" rel="noopener noreferrer" class="mobile-menu-link" id="mobile-github-link">github <span class="star-count"><span class="star-icon">★</span>{starsLabel}</span></a>
                    </div>
                </div>
            </header>

            <main>
                <!-- 1. Hero -->
                <section class="hero">
                    <div class="hero-text">
                        <h1 class="hero-headline">
                            Build reliably on
                            <em>object&nbsp;storage.</em>
                        </h1>
                        <p class="hero-sub">
                        SlateDB is an OSS embedded key-value database and LSM-engine built on object storage. 
                        </p>
                        <div class="hero-ctas">
                            <a class="cta cta-primary" href="/docs/get-started/introduction/">Read the docs</a>
                            <a class="cta cta-secondary" href="https://github.com/slatedb/slatedb" target="_blank" rel="noopener noreferrer">
                                <span>GitHub</span>
                            </a>
                        </div>
                    </div>
                    <div class="hero-art" aria-hidden="true">
                        <img src="/img/slate-atlas.png" alt="" width="1122" height="1402" loading="eager" decoding="async" />
                    </div>
                </section>

                <!-- 2 + 3. One plate: used-by logos (top row), editorial lead,
                     and the object-storage property strip. -->
                <section class="prose">
                    <div class="os-panel">
                        <div class="usedby" aria-label="Used by">
                            <div class="usedby-row">
                                {usedBy.map((c) => (
                                    <a href={c.href} target="_blank" rel="noopener noreferrer" class="usedby-logo" style={c.scale ? `--logo-scale: ${c.scale}` : undefined}>
                                        <img src={c.logo} alt={c.name} />
                                    </a>
                                ))}
                            </div>
                        </div>
                        <p class="prose-lead">
                        SlateDB brings the durability, consistency, and economics of object storage to your online systems without sacrificing performance or paying per-request API costs.
                        </p>
                        <div class="os-stats" aria-label="SlateDB at a glance">
                            {osLinks.map((l) => (
                                <a
                                    class="os-stat"
                                    href={l.href}
                                    target={l.external ? '_blank' : undefined}
                                    rel={l.external ? 'noopener noreferrer' : undefined}
                                >
                                    <span class="os-stat-kicker">
                                        {l.kicker}
                                        <span class="os-stat-arrow" aria-hidden="true">→</span>
                                    </span>
                                    <span class="os-stat-icons" data-count={l.icons.length}>
                                        {l.icons.map((ic) => (
                                            <span class="os-stat-icon" title={ic.label} set:html={ic.svg}></span>
                                        ))}
                                    </span>
                                    <span class="os-stat-desc">{l.desc}</span>
                                </a>
                            ))}
                        </div>
                    </div>
                </section>

                <!-- 4. Feature plate -->
                <section class="features" aria-label="Features">
                    <div class="features-head">
                        <h2 class="section-eyebrow">the engine</h2>
                    </div>
                    <div class="feature-plate" data-feature-plate>
                        <div class="plate-main">
                            <div class="plate-figure-stack" aria-label="Feature figure">
                                {features.map((f, i) => (
                                    <article
                                        id={`feature-panel-${f.id}`}
                                        class={`plate-panel ${i === 0 ? 'active' : ''}`}
                                        role="tabpanel"
                                        aria-labelledby={`feature-tab-${f.id}`}
                                        data-feature-panel={f.id}
                                    >
                                        <span class="plate-figure-marker">{f.figure}</span>
                                        {f.figureImg && (
                                            <img class={`plate-figure-img ${f.figureScaled ? 'plate-figure-img--scaled' : ''}`} src={f.figureImg} alt="" aria-hidden="true" />
                                        )}
                                        {f.href && (
                                            <a class="plate-figure-ref" href={f.href}>
                                                <span class="plate-figure-ref-label">ref</span>
                                                <span class="plate-figure-ref-path">{f.href}</span>
                                                <span class="plate-figure-ref-arrow" aria-hidden="true">→</span>
                                            </a>
                                        )}
                                    </article>
                                ))}
                            </div>
                            <div class="plate-copy-stack">
                                <div class="plate-copy-panels">
                                    {features.map((f, i) => (
                                        <article
                                            class={`plate-copy ${i === 0 ? 'active' : ''}`}
                                            data-feature-copy={f.id}
                                        >
                                            <h3 class="feature-name">{f.name}</h3>
                                            <p class="feature-body" set:html={f.body}></p>
                                            {f.href && (
                                                <a class="plate-copy-ref" href={f.href}>
                                                    <span class="plate-figure-ref-label">ref</span>
                                                    <span class="plate-figure-ref-path">{f.href}</span>
                                                    <span class="plate-figure-ref-arrow" aria-hidden="true">→</span>
                                                </a>
                                            )}
                                        </article>
                                    ))}
                                </div>
                                <div class="plate-tabs" role="tablist" aria-label="Feature figures">
                                    {features.map((f, i) => (
                                        <button
                                            id={`feature-tab-${f.id}`}
                                            class={`plate-tab ${i === 0 ? 'active' : ''}`}
                                            type="button"
                                            role="tab"
                                            aria-selected={i === 0 ? 'true' : 'false'}
                                            aria-controls={`feature-panel-${f.id}`}
                                            data-feature-tab={f.id}
                                        >
                                            <span>
                                                <span class="feature-index">{['I', 'II', 'III', 'IV', 'V'][i]}</span>
                                                {f.name}
                                            </span>
                                            <span class="plate-tab-tag">{f.figureTitle}</span>
                                        </button>
                                    ))}
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- 5. Quickstart -->
                <section class="quickstart" aria-label="Quickstart">
                    <div class="quickstart-head">
                        <h2 class="section-eyebrow">quickstart</h2>
                        <a class="quickstart-more" href="/docs/get-started/quickstart/">full quickstart →</a>
                    </div>
                    <div class="qs-card">
                        <div class="qs-tabs" role="tablist">
                            <div class="qs-dots" aria-hidden="true">
                                <span></span><span></span><span></span>
                            </div>
                            {langs.map((l, i) => (
                                <button
                                    class={`qs-tab ${i === 0 ? 'active' : ''}`}
                                    data-tab={l.id}
                                    role="tab"
                                    aria-selected={i === 0 ? 'true' : 'false'}
                                >{l.label}</button>
                            ))}
                        </div>
                        {langs.map((l, i) => (
                            <div class={`qs-pane ${i === 0 ? 'active' : ''}`} data-content={l.id}>
                                <div class="qs-install">
                                    <span class="qs-prompt">$</span>
                                    <code>{l.install}</code>
                                    <button class="qs-copy" type="button" data-copy={l.install} aria-label="Copy install command">
                                        <svg class="qs-copy-icon qs-copy-icon-clip" viewBox="0 0 24 24" width="14" height="14" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                                            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
                                        </svg>
                                        <svg class="qs-copy-icon qs-copy-icon-check" viewBox="0 0 24 24" width="14" height="14" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <polyline points="20 6 9 17 4 12"></polyline>
                                        </svg>
                                    </button>
                                </div>
                                <pre class="qs-code"><code set:html={highlight(l.code, l.id)}></code></pre>
                            </div>
                        ))}
                    </div>
                </section>

                <!-- 6. Closing CTA -->
                <section class="closing" aria-label="Read the docs">
                    <!-- Doric colonnade flanking the closing block. Four
                         distinct variants are arranged two per side; the right
                         side is mirrored via CSS scaleX(-1) so the inner-facing
                         edges of all four point toward the headline. -->
                    <div class="closing-colonnade closing-colonnade-left" aria-hidden="true">
                        <img src="/img/slate-doric.png" alt="" width="1122" height="1402" loading="lazy" decoding="async" />
                        <img src="/img/slate-doric-2.png" alt="" width="1122" height="1402" loading="lazy" decoding="async" />
                    </div>
                    <div class="closing-colonnade closing-colonnade-right" aria-hidden="true">
                        <img src="/img/slate-doric-3.png" alt="" width="1122" height="1402" loading="lazy" decoding="async" />
                        <img src="/img/slate-doric-4.png" alt="" width="1122" height="1402" loading="lazy" decoding="async" />
                    </div>
                    <div class="closing-text">
                        <h2 class="closing-headline">Ready to build?</h2>
                        <p class="closing-sub">
                            The full reference covers architecture, operations, tutorials, and the RFC archive.
                        </p>
                        <div class="closing-ctas">
                            <a class="cta cta-primary" href="/docs/get-started/introduction/">Read the docs</a>
                            <a class="cta cta-secondary" href="https://github.com/slatedb/slatedb" target="_blank" rel="noopener noreferrer">
                                <span>View on GitHub</span>
                            </a>
                        </div>
                    </div>
                </section>
            </main>

            <footer class="footer">
                <div class="footer-content">
                    <div class="footer-icons">
                        <SocialIcons />
                    </div>
                    <div class="copyright-wrapper">
                        <p>
                            <img src="https://raw.githubusercontent.com/commonhaus/artwork/main/foundation/brand/svg/CF_logo_horizontal_single_default.svg" height="20" alt="Commonhaus Foundation"/><br />
                            Copyright © <a href="https://slatedb.io">SlateDB</a>. All rights reserved. For details on our trademarks, please visit our <a href="https://www.commonhaus.org/policies/trademark-policy/">Trademark Policy</a> and <a href="https://www.commonhaus.org/trademarks/">Trademark List</a>.<br/>
                            Trademarks of third parties are owned by their respective holders and their mention here does not suggest any endorsement or association.
                        </p>
                    </div>
                </div>
            </footer>
        </div>
    </body>
</html>

<style>
    /* ---------------------------------------------------------------
     * Tokens consumed from custom.css. Fallbacks defined here so the
     * landing remains coherent if custom.css fails to load.
     * ------------------------------------------------------------- */
    :root {
        --ink-1: #0f1620;
        --ink-2: #1f2a37;
        --ink-3: #3d4856;
        --ink-4: #5e6878;
        --ink-5: #8b94a3;
        --ink-6: #c8cdd5;
        --ink-7: #dfe2e8;
        --surface-0: #f6f7f9;
        --surface-1: #ffffff;
        --surface-2: #eef0f3;
        --surface-3: #e2e6eb;
        --accent-high: #7a3e22;
        --accent: #b26844;
        --accent-low: #f3e3d8;
    }

    html, body {
        margin: 0;
        padding: 0;
        background-color: var(--surface-0);
        color: var(--ink-2);
        font-family:
            'Inter', ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
            'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        text-rendering: optimizeLegibility;
    }

    body { min-height: 100vh; }

    .page {
        display: flex;
        flex-direction: column;
        min-height: 100vh;
        position: relative;
        /* Cool off-white base + a faint terracotta glow radiating from the
           top-right corner (anchored near the hero figure). Soft and small. */
        background:
            radial-gradient(circle at 100% 0%, rgba(178, 104, 68, 0.08), transparent 28%),
            var(--surface-0);
        isolation: isolate;
    }

    /* Architectural-sketch bg currently hidden — atlas hero image carries the visual weight. */

    /* ---------- Header ---------- */

    .header {
        position: sticky;
        top: 0;
        z-index: 100;
        /* Translucent enough that the terracotta corner glow on .page tints
           the navbar instead of being clipped at its lower edge. */
        background-color: rgba(246, 247, 249, 0.45);
        backdrop-filter: saturate(180%) blur(16px);
        -webkit-backdrop-filter: saturate(180%) blur(16px);
        /* Match main's scaling inline padding so the header tracks the
           content's left/right edges as the viewport grows. */
        padding: 1rem clamp(1.5rem, 4vw, 4rem);
    }

    .header-content {
        display: flex;
        align-items: center;
        justify-content: space-between;
        max-width: 80rem;
        margin: 0 auto;
        position: relative;
    }

    .site-title { display: inline-flex; align-items: center; }
    .site-title img { height: 1.6rem; width: auto; }

    .right-group {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .header-links {
        display: flex;
        gap: 1.5rem;
        align-items: center;
    }

    .header-link {
        font-size: 0.8125rem;
        font-family:
            'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
        color: var(--ink-2);
        text-decoration: none;
        transition: color 0.15s ease;
        display: inline-flex;
        align-items: center;
    }
    .header-link:hover { color: var(--accent); }
    .header-link .star-count,
    .mobile-menu-link .star-count {
        display: inline-flex;
        align-items: center;
        gap: 0.2rem;
        margin-left: 0.55rem;
        padding: 0.12rem 0.45rem;
        background-color: var(--surface-1);
        border: 1px solid var(--ink-6);
        border-radius: 0;
        color: var(--ink-2);
        font-size: 0.72rem;
        font-weight: 500;
        line-height: 1;
        transition: border-color 0.15s ease, background-color 0.15s ease;
    }
    .header-link:hover .star-count,
    .mobile-menu-link:hover .star-count {
        border-color: var(--ink-4);
    }
    .header-link .star-count .star-icon,
    .mobile-menu-link .star-count .star-icon {
        color: var(--accent);
        font-size: 0.8rem;
        line-height: 1;
    }

    .mobile-menu-toggle {
        display: none;
        background: none;
        border: none;
        cursor: pointer;
        padding: 0.5rem;
        margin: -0.5rem;
        position: relative;
        width: 2rem;
        height: 2rem;
        color: var(--ink-2);
    }

    .menu-icon {
        position: absolute;
        inset: 0.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: opacity 0.15s ease;
    }
    .menu-icon svg { width: 1rem; height: 1rem; fill: currentColor; }
    .menu-icon-times { opacity: 0; }
    .mobile-menu-toggle[aria-expanded='true'] .menu-icon-bars { opacity: 0; }
    .mobile-menu-toggle[aria-expanded='true'] .menu-icon-times { opacity: 1; }

    .mobile-menu {
        display: none;
        flex-direction: column;
        gap: 0.5rem;
        padding: 1rem 1.5rem;
        background-color: var(--surface-0);
        border-top: 1px solid var(--ink-6);
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
    }
    .mobile-menu.open { display: flex; }
    .mobile-menu-link {
        font-family:
            'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 0.875rem;
        color: var(--ink-2);
        text-decoration: none;
        padding: 0.5rem 0;
    }

    @media (max-width: 768px) {
        .header-links { display: none; }
        .mobile-menu-toggle { display: flex; }
    }

    /* ---------- Hero ---------- */

    main {
        max-width: 80rem;
        margin: 0 auto;
        /* Inline padding scales with viewport so content keeps breathing room
           on both sides instead of going flush at widths near max-width. */
        padding: 0 clamp(1.5rem, 4vw, 4rem);
        width: 100%;
        box-sizing: border-box;
    }

    .hero {
        padding: 7rem 0 5rem;
        position: relative;
        isolation: isolate;
    }
    /* Faint grid that fades to nothing at the edges. Sits behind everything in
       the hero (Atlas figure, text). */
    .hero::before {
        content: "";
        position: absolute;
        /* Extend the grid down past the hero (negative bottom inset) so it
           continues through the "used by" + prose sections instead of cutting
           off at the hero's edge. */
        inset: 0 0 -28rem 0;
        pointer-events: none;
        opacity: 0.18;
        background-image:
            linear-gradient(rgba(80, 70, 55, 0.16) 1px, transparent 1px),
            linear-gradient(90deg, rgba(80, 70, 55, 0.16) 1px, transparent 1px);
        background-size: 72px 72px;
        /* Mask is biased upward (28% from top) so the brightest patch still
           sits around the hero text now that the element is taller. */
        -webkit-mask-image: radial-gradient(ellipse 60% 65% at 50% 28%, black 0%, transparent 100%);
        mask-image: radial-gradient(ellipse 60% 65% at 50% 28%, black 0%, transparent 100%);
        z-index: -1;
    }
    .hero-text {
        max-width: 36rem;
        position: relative;
        z-index: 1;
    }
    /* Atlas sits to the right like a background image — absolutely positioned
       so it never adds vertical height to the hero. Anchored to the top so the
       figure isn't clipped above the hero. Slightly transparent so it reads
       as art rather than a foreground subject. */
    .hero-art {
        position: absolute;
        top: -2rem;
        right: -1rem;
        /* Fixed size — the figure does not scale with the viewport; it just
           gets hidden below 767px. */
        width: 36rem;
        pointer-events: none;
        z-index: 0;
        opacity: 0.8;
        filter: blur(0.25px);
    }
    .hero-art img {
        width: 100%;
        height: auto;
        display: block;
        opacity: 0.6;
    }
    @media (max-width: 767px) {
        .hero { padding: 5rem 0 4rem; }
        .hero-art { display: none; }
    }

    .hero-headline {
        font-family:
            'Marcellus', ui-serif, Georgia, 'Times New Roman', serif;
        font-weight: 400;
        /* Fixed size — does not scale with the viewport; wraps onto more lines
           as the page narrows instead. */
        font-size: 3rem;
        line-height: 1.1;
        letter-spacing: -0.005em;
        color: var(--ink-1);
        margin: 0;
    }
    /* Marcellus has no italic style — convey emphasis via color, not slant
       (browser faux-italic looks rough on classical inscriptional faces). */
    .hero-headline em {
        font-style: normal;
        color: var(--accent-high);
    }

    .hero-sub {
        margin: 1.5rem 0 0;
        font-size: 1.0625rem;
        line-height: 1.6;
        color: var(--ink-3);
        max-width: 36rem;
    }
    /* On medium screens the atlas is still visible on the right, so tighten the
       subtitle's max-width to push the wrap earlier and keep text clear of the figure. */
    @media (max-width: 1199px) {
        .hero-sub { max-width: 26rem; }
    }
    @media (max-width: 991px) {
        .hero-sub { max-width: 20rem; }
    }
    /* Below 767px the atlas is gone, so the hero text reclaims the full width.
       Placed after the rules above so it wins on source order at this width. */
    @media (max-width: 767px) {
        .hero-text { max-width: none; }
        .hero-sub { max-width: none; }
    }

    .hero-ctas {
        display: flex;
        gap: 0.75rem;
        margin-top: 2rem;
        flex-wrap: wrap;
    }

    .cta {
        font-family:
            'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 0.8125rem;
        padding: 0.7rem 1.1rem;
        border-radius: 0;
        text-decoration: none;
        transition: all 0.15s ease;
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
    }
    .cta-primary {
        background-color: var(--ink-1);
        color: var(--surface-0);
    }
    .cta-primary:hover {
        background-color: var(--accent-high);
    }
    .cta-secondary {
        background-color: transparent;
        color: var(--ink-2);
        border: 1px solid var(--ink-6);
    }
    .cta-secondary:hover {
        border-color: var(--ink-4);
        color: var(--ink-1);
    }
    /* ---------- Used-by — evenly spaced, uniform-height logos ---------- */

    /* Top row of the panel: frosted like the lead beneath it, with a hairline
       divider separating it from the lead. Horizontal padding matches the lead. */
    .usedby {
        padding: 1.5rem 1.75rem 1.25rem;
        position: relative;
        border-bottom: 1px solid var(--ink-6);
        background-color: rgba(246, 247, 249, 0.4);
        backdrop-filter: blur(14px) saturate(140%);
        -webkit-backdrop-filter: blur(14px) saturate(140%);
    }

    /* Even-width cells via grid; each logo fills its cell at uniform height.
       auto-fit packs as many ~100px cells as the viewport allows. */
    .usedby-row {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(80px, 1fr));
        gap: 0.75rem 1.25rem;
        align-items: center;
        justify-items: center;
    }

    .usedby-logo {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        height: 1.25rem;
        width: 100%;
    }
    .usedby-logo img {
        height: 100%;
        width: auto;
        max-width: 100%;
        object-fit: contain;
        transform: scale(var(--logo-scale, 1));
        transform-origin: center;
        filter: grayscale(100%);
        opacity: 0.55;
        transition: opacity 0.2s ease, filter 0.2s ease;
    }
    .usedby-logo:hover img {
        opacity: 0.95;
        filter: grayscale(0%);
    }

    /* ---------- Editorial prose ---------- */

    .prose {
        padding: 2rem 0 6rem;
        position: relative;
    }
    .prose p {
        position: relative;
        z-index: 1;
        font-family:
            'Source Serif 4', ui-serif, Georgia, serif;
        font-weight: 500;
        font-size: clamp(1.125rem, 2.6vw, 1.5rem);
        line-height: 1.55;
        color: var(--ink-1);
        margin: 0;
        font-variation-settings: 'opsz' 24;
        letter-spacing: -0.005em;
    }
    .prose em {
        font-style: italic;
        font-weight: 500;
        color: var(--accent-high);
    }
    /* One bordered plate: a full-width lead row spanning all columns, then a
       three-cell property strip beneath it. Matches the feature plate — sharp
       corners, 1px ink border, warm gridded "paper" backdrop. */
    .os-panel {
        position: relative;
        z-index: 1;
        border: 1px solid var(--ink-6);
        /* overflow visible so the used-by label chips can break the top border. */
    }
    /* Lead sentence keeps the editorial serif voice but no longer carries the
       whole message — the property strip below it does the heavy lifting. It
       spans the full width as the plate's top row. Left transparent with a
       frosted backdrop so the Atlas figure shows through, softly blurred. */
    /* Selector must out-specify `.prose p` (0,1,1) — a bare `.prose-lead`
       (0,1,0) loses to it and the overrides below silently don't apply. */
    .prose p.prose-lead {
        margin: 0;
        padding: 1.75rem 3.75rem 1.75rem;
        border-bottom: 1px solid var(--ink-6);
        background-color: rgba(246, 247, 249, 0.4);
        /* Very light blur so the hero grid/atlas showing through softens. */
        backdrop-filter: blur(0.5px);
        -webkit-backdrop-filter: blur(0.5px);
        /* Sized and set to match the feature body copy (.plate-copy
           .feature-body) rather than the big editorial serif from .prose p. */
        font-family: 'Inter', ui-sans-serif, system-ui, -apple-system, sans-serif;
        font-weight: 400;
        font-size: 1rem;
        line-height: 1.62;
        letter-spacing: normal;
        font-variation-settings: normal;
    }

    /* Three linked property cells: mono kicker label + a row of brand glyphs +
       a supporting line. Each cell is a docs/repo link. The warm gridded "paper"
       backdrop lives here, beneath the cells only. */
    .os-stats {
        margin: 0;
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        background-color: #f8f6f3;
    }
    .os-stat {
        padding: 1.5rem 1.5rem 1.6rem;
        display: flex;
        flex-direction: column;
        gap: 0.9rem;
        position: relative;
        text-decoration: none;
        color: inherit;
        transition: background-color 0.18s ease;
    }
    .os-stat:hover {
        background-color: rgba(178, 104, 68, 0.05);
    }
    /* Hairline separators between cells, matching the gridded plate look. */
    .os-stat + .os-stat {
        border-left: 1px solid var(--ink-6);
    }
    .os-stat-kicker {
        display: flex;
        align-items: center;
        justify-content: space-between;
        font-family:
            'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
        font-size: 0.68rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--ink-4);
    }
    .os-stat-arrow {
        color: var(--ink-6);
        transition: color 0.18s ease, transform 0.18s ease;
    }
    .os-stat:hover .os-stat-arrow {
        color: var(--accent);
        transform: translateX(0.2rem);
    }
    /* Glyph row. Icons are inlined single-path SVGs tinted via currentColor;
       they sit muted (ink + low opacity, grayscale aesthetic) and warm to the
       accent on hover, echoing the used-by logo treatment. */
    .os-stat-icons {
        display: flex;
        align-items: center;
        gap: 0.85rem;
        min-height: 2rem;
        margin-top: auto;
    }
    .os-stat-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: var(--ink-3);
        opacity: 0.7;
        transition: color 0.18s ease, opacity 0.18s ease;
    }
    .os-stat-icon :global(svg) {
        display: block;
        width: 1.6rem;
        height: 1.6rem;
        fill: currentColor;
    }
    .os-stat:hover .os-stat-icon {
        color: var(--accent-high);
        opacity: 1;
    }
    /* The license cell carries a single emblem — let it read larger. */
    .os-stat-icons[data-count='1'] .os-stat-icon :global(svg) {
        width: 2.1rem;
        height: 2.1rem;
    }
    .os-stat-desc {
        font-size: 0.85rem;
        line-height: 1.45;
        color: var(--ink-3);
    }

    @media (max-width: 640px) {
        .os-stats {
            grid-template-columns: 1fr;
        }
        .os-stat + .os-stat {
            border-left: 0;
            border-top: 1px solid var(--ink-6);
        }
        .os-stat-icons {
            margin-top: 0;
        }
    }

    /* ---------- Section eyebrows ---------- */

    .section-eyebrow {
        font-family:
            'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 0.7rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--ink-4);
        margin: 0 0 1.5rem;
        font-weight: 500;
    }

    /* ---------- Feature grid ---------- */

    .features {
        padding: 0 0 6rem;
    }
    .features-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1px;
        background-color: var(--ink-6);
         border: 1px solid var(--ink-6);
        border-radius: 0.75rem;
        overflow: hidden;
        margin-top: 1.5rem;
    }
    @media (max-width: 900px) {
        .features-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 560px) {
        .features-grid { grid-template-columns: 1fr; }
    }

    .feature {
        /* Each tile's hover glow points back toward the grid's center, so
           the six glows together read as one shared light source. Per-tile
           coordinates set below via :nth-child(), adjusted per breakpoint. */
        --glow-x: 50%;
        --glow-y: 50%;
        background-color: var(--surface-1);
        padding: 1.75rem 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        position: relative;
        transition: background 0.2s ease;
    }
    .feature:hover {
        background:
            radial-gradient(circle at var(--glow-x) var(--glow-y), rgba(178, 104, 68, 0.12), transparent 75%),
            var(--surface-1);
    }
    /* 3 cols × 2 rows — grid center sits between cols 2&3 and rows 1&2. */
    .features-grid > :nth-child(1) { --glow-x: 100%; --glow-y: 100%; }
    .features-grid > :nth-child(2) { --glow-x: 50%;  --glow-y: 100%; }
    .features-grid > :nth-child(3) { --glow-x: 0%;   --glow-y: 100%; }
    .features-grid > :nth-child(4) { --glow-x: 100%; --glow-y: 0%; }
    .features-grid > :nth-child(5) { --glow-x: 50%;  --glow-y: 0%; }
    .features-grid > :nth-child(6) { --glow-x: 0%;   --glow-y: 0%; }
    @media (max-width: 900px) {
        /* 2 cols × 3 rows */
        .features-grid > :nth-child(1) { --glow-x: 100%; --glow-y: 100%; }
        .features-grid > :nth-child(2) { --glow-x: 0%;   --glow-y: 100%; }
        .features-grid > :nth-child(3) { --glow-x: 100%; --glow-y: 50%; }
        .features-grid > :nth-child(4) { --glow-x: 0%;   --glow-y: 50%; }
        .features-grid > :nth-child(5) { --glow-x: 100%; --glow-y: 0%; }
        .features-grid > :nth-child(6) { --glow-x: 0%;   --glow-y: 0%; }
    }
    @media (max-width: 560px) {
        /* 1 col × 6 rows — center is between rows 3 and 4 */
        .features-grid > :nth-child(1),
        .features-grid > :nth-child(2),
        .features-grid > :nth-child(3) { --glow-x: 50%; --glow-y: 100%; }
        .features-grid > :nth-child(4),
        .features-grid > :nth-child(5),
        .features-grid > :nth-child(6) { --glow-x: 50%; --glow-y: 0%; }
    }
    .feature-tag {
        font-family:
            'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 0.7rem;
        color: var(--ink-4);
        margin-bottom: 0.25rem;
        padding-bottom: 0.5rem;
        position: relative;
        transition: color 0.15s ease;
    }
    /* Short rule under each feature's tag — picks up the "engineering plate"
       feel from the .usedby border-labels. Color and width animate on hover
       to track the tile's own hover state. */
    .feature-tag::after {
        content: '';
        position: absolute;
        left: 0;
        bottom: 0;
        width: 1.25rem;
        height: 1px;
        background-color: var(--ink-6);
        transition: background-color 0.2s ease, width 0.2s ease;
    }
    .feature:hover .feature-tag {
        color: var(--accent);
    }
    .feature:hover .feature-tag::after {
        background-color: var(--accent);
        width: 2rem;
    }
    /* Roman-numeral plate marker. Marcellus to echo the hero/closing headlines,
       sat opposite the .feature-tag so the two labelling systems (engineering
       comment vs. classical numeral) bracket the tile. */
    .feature-numeral {
        position: absolute;
        top: 1.4rem;
        right: 1.5rem;
        font-family:
            'Marcellus', ui-serif, Georgia, 'Times New Roman', serif;
        font-size: 1rem;
        line-height: 1;
        letter-spacing: 0.08em;
        color: var(--ink-6);
        user-select: none;
        transition: color 0.2s ease;
    }
    .feature:hover .feature-numeral {
        color: var(--accent);
    }
    .feature-name {
        font-family: 'Inter', system-ui, sans-serif;
        font-weight: 600;
        font-size: 1.0625rem;
        color: var(--ink-1);
        letter-spacing: -0.01em;
        margin: 0;
    }
    .feature-body {
        font-size: 0.9375rem;
        line-height: 1.55;
        color: var(--ink-3);
        margin: 0;
    }

    /* ---------- Feature plate prototype ---------- */

    .features-head {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(18rem, 31rem);
        gap: 2rem;
        align-items: end;
        margin-bottom: 1.5rem;
    }
    .features-head .section-eyebrow {
        margin: 0;
    }
    .features-summary {
        margin: 0;
        font-family:
            'Source Serif 4', ui-serif, Georgia, serif;
        font-size: 1.125rem;
        line-height: 1.55;
        color: var(--ink-2);
        font-variation-settings: 'opsz' 18;
    }

    .feature-plate {
        display: grid;
        grid-template-columns: minmax(0, 1.05fr) minmax(24rem, 0.95fr);
        border: 1px solid var(--ink-6);
        overflow: hidden;
    }

    .plate-figure {
        min-height: 31rem;
        padding: 1.5rem;
        border-right: 1px solid var(--ink-6);
        display: flex;
        flex-direction: column;
        position: relative;
        background:
            linear-gradient(rgba(80, 70, 55, 0.08) 1px, transparent 1px),
            linear-gradient(90deg, rgba(80, 70, 55, 0.08) 1px, transparent 1px),
            var(--surface-0);
        background-size: 36px 36px, 36px 36px, auto;
    }

    .plate-label,
    .plate-footnotes,
    .feature-meta,
    .feature-points {
        font-family:
            'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    }

    .plate-label {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        padding-bottom: 0.85rem;
        border-bottom: 1px solid rgba(200, 205, 213, 0.85);
        font-size: 0.7rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--ink-4);
    }

    .lsm-diagram {
        flex: 1;
        display: grid;
        grid-template-columns: minmax(10rem, 1fr) minmax(6rem, 0.45fr) minmax(10rem, 1fr);
        gap: 1rem;
        align-items: center;
        padding: 2rem 0;
        min-height: 20rem;
    }

    .diagram-node {
        min-height: 8.5rem;
        padding: 1.1rem;
        border: 1px solid var(--ink-6);
        border-radius: 0.5rem;
        background-color: rgba(255, 255, 255, 0.76);
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 0.55rem;
        box-shadow: 0 1px 2px rgba(27, 36, 47, 0.03);
    }
    .diagram-node strong {
        font-family:
            'Marcellus', ui-serif, Georgia, 'Times New Roman', serif;
        font-size: 1.6rem;
        font-weight: 400;
        line-height: 1;
        color: var(--ink-1);
    }
    .diagram-node span:not(.diagram-kicker) {
        font-size: 0.875rem;
        line-height: 1.45;
        color: var(--ink-3);
    }
    .diagram-kicker {
        font-family:
            'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
        font-size: 0.68rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--ink-4);
    }
    .diagram-store {
        border-color: rgba(122, 62, 34, 0.36);
    }

    .diagram-link {
        position: relative;
        display: grid;
        gap: 0.35rem;
        justify-items: center;
        align-content: center;
        min-height: 10rem;
        color: var(--ink-4);
    }
    .diagram-link::before {
        content: '';
        position: absolute;
        left: -1.25rem;
        right: -1.25rem;
        top: 50%;
        height: 1px;
        background: linear-gradient(90deg, var(--ink-6), var(--accent), var(--ink-6));
    }
    .diagram-link::after {
        content: '';
        position: absolute;
        right: -1.35rem;
        top: calc(50% - 0.22rem);
        width: 0.45rem;
        height: 0.45rem;
        border-top: 1px solid var(--accent);
        border-right: 1px solid var(--accent);
        transform: rotate(45deg);
        background-color: transparent;
    }
    .diagram-link span {
        position: relative;
        z-index: 1;
        padding: 0.12rem 0.3rem;
        background-color: var(--surface-0);
        font-family:
            'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
        font-size: 0.68rem;
        line-height: 1.2;
    }

    .plate-footnotes {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 0.75rem;
        padding-top: 0.85rem;
        border-top: 1px solid rgba(200, 205, 213, 0.85);
        font-size: 0.68rem;
        color: var(--ink-4);
    }

    .feature-callouts {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 1px;
        background-color: var(--ink-6);
    }

    .feature-callouts .feature {
        --glow-x: 100%;
        --glow-y: 0%;
        background-color: var(--surface-1);
        padding: 1.35rem 1.25rem;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        min-height: 13.5rem;
        position: relative;
        transition: background 0.2s ease;
    }
    .feature-callouts .feature:hover {
        background:
            radial-gradient(circle at var(--glow-x) var(--glow-y), rgba(178, 104, 68, 0.12), transparent 70%),
            var(--surface-1);
    }

    .feature-meta {
        display: flex;
        align-items: center;
        gap: 0.65rem;
        padding-bottom: 0.65rem;
        border-bottom: 1px solid var(--ink-7);
        font-size: 0.68rem;
        color: var(--ink-4);
    }
    .feature-index {
        color: var(--accent-high);
    }
    .feature-callouts .feature-tag {
        color: var(--ink-4);
        margin: 0;
        padding: 0;
        position: static;
    }
    .feature-callouts .feature-tag::after {
        content: none;
    }
    .feature-callouts .feature-name {
        letter-spacing: 0;
    }
    .feature-callouts .feature-body {
        font-size: 0.9rem;
        line-height: 1.58;
    }
    .feature-points {
        list-style: none;
        margin: auto 0 0;
        padding: 0;
        display: grid;
        gap: 0.35rem;
        font-size: 0.68rem;
        color: var(--ink-4);
    }
    .feature-points li {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        min-width: 0;
    }
    .feature-points li::before {
        content: '';
        flex: 0 0 0.75rem;
        height: 1px;
        background-color: var(--accent);
        opacity: 0.7;
    }

    @media (max-width: 980px) {
        .features-head,
        .feature-plate {
            grid-template-columns: 1fr;
        }
        .plate-figure {
            border-right: 0;
            border-bottom: 1px solid var(--ink-6);
            min-height: 27rem;
        }
    }

    @media (max-width: 640px) {
        .features-summary {
            font-size: 1rem;
        }
        .plate-figure {
            min-height: auto;
        }
        .plate-label {
            display: grid;
            gap: 0.35rem;
        }
        .plate-footnotes {
            grid-template-columns: 1fr;
        }
        .lsm-diagram {
            grid-template-columns: 1fr;
            min-height: auto;
            padding: 1.5rem 0;
        }
        .diagram-link {
            min-height: 4rem;
        }
        .diagram-link::before {
            left: 50%;
            right: auto;
            top: -0.25rem;
            bottom: -0.25rem;
            width: 1px;
            height: auto;
            background: linear-gradient(var(--ink-6), var(--accent), var(--ink-6));
        }
        .diagram-link::after {
            right: auto;
            left: calc(50% - 0.22rem);
            top: auto;
            bottom: -0.25rem;
            transform: rotate(135deg);
        }
        .feature-callouts {
            grid-template-columns: 1fr;
        }
        .feature-callouts .feature {
            min-height: auto;
        }
    }

    /* ---------- Selectable feature plate ---------- */

    .feature-plate {
        display: block;
    }

    .plate-main {
        display: grid;
        grid-template-columns: minmax(20rem, 0.8fr) minmax(0, 1fr);
        min-height: 34rem;
    }

    .plate-figure-stack {
        position: relative;
        order: 2;
        display: grid;
        min-height: 34rem;
        border-left: 1px solid var(--ink-6);
        background:
            linear-gradient(rgba(122, 62, 34, 0.05) 1px, transparent 1px),
            linear-gradient(90deg, rgba(122, 62, 34, 0.05) 1px, transparent 1px),
            #f8f6f3;
        background-size: 36px 36px, 36px 36px, auto;
    }

    .plate-panel {
        position: relative;
        grid-area: 1 / 1;
        min-height: 34rem;
        padding: 0.5rem;
        display: none;
        flex-direction: column;
        overflow: hidden;
    }
    .plate-panel.active {
        display: flex;
    }
    .plate-figure-marker {
        position: absolute;
        top: 1.25rem;
        right: 1.25rem;
        font-family:
            'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
        font-size: 0.7rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--ink-4);
    }
    .plate-figure-img {
        flex: 1;
        min-height: 0;
        width: 100%;
        height: 100%;
        object-fit: contain;
        pointer-events: none;
    }
    .plate-figure-img--scaled {
        transform: translateY(2rem) scale(1.15);
        transform-origin: center;
    }
    .plate-figure-ref {
        position: absolute;
        top: 1.25rem;
        left: 1.25rem;
        z-index: 1;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-family:
            'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
        font-size: 0.7rem;
        letter-spacing: 0.04em;
        color: var(--ink-3);
        text-decoration: none;
        transition: color 0.15s ease;
    }
    .plate-figure-ref-label {
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--ink-4);
    }
    .plate-figure-ref-path {
        color: var(--accent);
        font-weight: 500;
        transition: color 0.15s ease;
    }
    .plate-figure-ref:hover .plate-figure-ref-path {
        color: var(--accent-high);
    }
    .plate-figure-ref-arrow {
        color: var(--accent);
        transition: transform 0.15s ease, color 0.15s ease;
    }
    .plate-figure-ref:hover .plate-figure-ref-arrow {
        color: var(--accent-high);
        transform: translateX(0.2rem);
    }

    /* Inline ref shown only on mobile, where the figure (and its ref) is hidden. */
    .plate-copy-ref {
        display: none;
        align-items: center;
        gap: 0.5rem;
        margin-top: 1rem;
        font-family:
            'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
        font-size: 0.7rem;
        letter-spacing: 0.04em;
        color: var(--ink-3);
        text-decoration: none;
    }
    .plate-copy-ref:hover .plate-figure-ref-path,
    .plate-copy-ref:hover .plate-figure-ref-arrow {
        color: var(--accent-high);
    }
    .plate-copy-ref:hover .plate-figure-ref-arrow {
        transform: translateX(0.2rem);
    }

    .plate-copy-stack {
        position: relative;
        order: 1;
        display: flex;
        flex-direction: column;
    }
    .plate-copy-panels {
        position: relative;
        flex: 1;
        display: grid;
    }

    .plate-copy {
        grid-area: 1 / 1;
        padding: 2rem;
        display: flex;
        flex-direction: column;
        gap: 0.9rem;
        visibility: hidden;
    }
    .plate-copy.active {
        visibility: visible;
    }

    .plate-copy .feature-tag {
        color: var(--ink-4);
        margin: 0;
        padding: 0;
        position: static;
    }
    .plate-copy .feature-tag::after {
        content: none;
    }
    .plate-copy .feature-name {
        font-family:
            'Marcellus', ui-serif, Georgia, 'Times New Roman', serif;
        font-weight: 400;
        font-size: 1.6rem;
        letter-spacing: 0;
    }
    .plate-copy .feature-body {
        font-size: 1rem;
        line-height: 1.62;
    }
    .plate-copy .feature-body :global(code) {
        font-family:
            'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
        font-size: 0.85em;
        padding: 0.1em 0.35em;
        border: 1px solid var(--ink-6);
        border-radius: 0.25rem;
        background-color: var(--surface-2);
        color: var(--accent-high);
        white-space: nowrap;
    }

    .plate-diagram {
        flex: 1;
        display: grid;
        align-items: center;
        gap: 1rem;
        padding: 2rem 0;
        min-height: 22rem;
    }

    .diagram-zero {
        grid-template-columns: minmax(10rem, 1fr) minmax(6rem, 0.45fr) minmax(10rem, 1fr);
    }

    .diagram-deployment {
        grid-template-columns: minmax(10rem, 0.9fr) minmax(9rem, 0.75fr) minmax(9rem, 0.9fr);
    }
    .diagram-hub {
        min-height: 8.5rem;
        padding: 1rem;
        border: 1px solid rgba(122, 62, 34, 0.36);
        border-radius: 50%;
        background-color: rgba(255, 255, 255, 0.78);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        gap: 0.45rem;
        position: relative;
    }
    .diagram-hub::before,
    .diagram-hub::after {
        content: '';
        position: absolute;
        top: 50%;
        width: 2rem;
        height: 1px;
        background-color: var(--accent);
        opacity: 0.7;
    }
    .diagram-hub::before { right: 100%; }
    .diagram-hub::after { left: 100%; }
    .diagram-hub strong {
        font-family:
            'Marcellus', ui-serif, Georgia, 'Times New Roman', serif;
        font-size: 1.35rem;
        font-weight: 400;
        line-height: 1;
        color: var(--ink-1);
    }

    .reader-grid,
    .perf-rail {
        display: grid;
        gap: 0.65rem;
    }
    .mini-node {
        padding: 0.8rem 0.85rem;
        border: 1px solid var(--ink-6);
        border-radius: 0.45rem;
        background-color: rgba(255, 255, 255, 0.74);
        font-family:
            'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
        font-size: 0.72rem;
        color: var(--ink-3);
    }

    .diagram-semantics {
        grid-template-columns: minmax(12rem, 1fr) minmax(11rem, 0.72fr);
    }
    .semantic-stack {
        display: grid;
        gap: 0.75rem;
    }
    .semantic-row {
        padding: 0.95rem 1rem;
        border: 1px solid var(--ink-6);
        border-radius: 0.45rem;
        background-color: rgba(255, 255, 255, 0.74);
        display: grid;
        gap: 0.35rem;
    }
    .semantic-row span {
        font-family:
            'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
        font-size: 0.68rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--ink-4);
    }
    .semantic-row strong {
        font-size: 0.95rem;
        color: var(--ink-1);
    }
    .semantic-gate {
        min-height: 12rem;
        padding: 1.1rem;
        border: 1px solid rgba(122, 62, 34, 0.36);
        border-radius: 0.5rem;
        background-color: rgba(255, 255, 255, 0.78);
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 0.55rem;
    }
    .semantic-gate strong {
        font-family:
            'Marcellus', ui-serif, Georgia, 'Times New Roman', serif;
        font-size: 1.55rem;
        font-weight: 400;
        color: var(--ink-1);
    }
    .semantic-gate span:not(.diagram-kicker) {
        color: var(--ink-3);
        line-height: 1.45;
    }

    .diagram-performance {
        grid-template-columns: minmax(8rem, 0.7fr) minmax(11rem, 1fr) minmax(8rem, 0.7fr);
    }
    .perf-core {
        border-color: rgba(122, 62, 34, 0.36);
    }

    .plate-tabs {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1px;
        background-color: var(--ink-6);
        border-top: 1px solid var(--ink-6);
    }
    .plate-tab {
        min-width: 0;
        padding: 0.95rem 1rem;
        border: 0;
        border-radius: 0;
        background-color: var(--surface-0);
        color: var(--ink-3);
        cursor: pointer;
        text-align: left;
        display: grid;
        gap: 0.35rem;
        transition: background-color 0.15s ease, color 0.15s ease;
    }
    .plate-tab:hover {
        background-color: var(--surface-1);
        color: var(--ink-1);
    }
    .plate-tab.active {
        background-color: var(--ink-1);
        color: var(--surface-0);
    }
    .plate-tab span:first-child {
        min-width: 0;
        font-family:
            'Inter', ui-sans-serif, system-ui, sans-serif;
        font-size: 0.86rem;
        font-weight: 600;
        line-height: 1.25;
    }
    .plate-tab .feature-index {
        margin-right: 0.45rem;
    }
    .plate-tab.active .feature-index {
        color: var(--accent-low);
    }
    .plate-tab-tag {
        font-family:
            'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
        font-size: 0.66rem;
        line-height: 1.25;
        color: var(--ink-4);
    }
    .plate-tab.active .plate-tab-tag {
        color: var(--ink-6);
    }

    @media (max-width: 980px) {
        .plate-main {
            grid-template-columns: 1fr;
        }
        .plate-figure-stack {
            border-left: 0;
            border-top: 1px solid var(--ink-6);
            min-height: 18rem;
        }
        .plate-panel {
            min-height: 18rem;
        }
    }

    @media (max-width: 640px) {
        .plate-figure-stack {
            display: none;
        }
        .plate-copy {
            padding: 1.25rem;
        }
        .plate-copy-ref {
            display: inline-flex;
        }
        .plate-diagram,
        .diagram-zero,
        .diagram-deployment,
        .diagram-semantics,
        .diagram-performance {
            grid-template-columns: 1fr;
            min-height: auto;
        }
        .diagram-link {
            min-height: 4rem;
        }
        .diagram-hub {
            border-radius: 0.5rem;
        }
        .diagram-hub::before,
        .diagram-hub::after {
            display: none;
        }
        .plate-tabs {
            grid-template-columns: 1fr;
        }
    }

    /* ---------- Quickstart ---------- */

    .quickstart {
        padding: 0 0 6rem;
    }
    .quickstart-head {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        margin-bottom: 1.5rem;
    }
    .quickstart-more {
        font-family:
            'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 0.8125rem;
        color: var(--accent);
        text-decoration: none;
    }
    .quickstart-more:hover { color: var(--accent-high); }

    .qs-card {
        /* Flat engineering-plate look to match the property panel: sharp corners,
           1px ink border, no shadow. Plain surface — no gridded paper. */
        border: 1px solid var(--ink-6);
        overflow: hidden;
        background-color: #f8f6f3;
    }

    .qs-tabs {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 0;
        padding: 0 0.5rem;
        border-bottom: 1px solid var(--ink-6);
        background-color: var(--surface-0);
    }
    .qs-dots {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        padding: 0 0.75rem 0 0.4rem;
        margin-right: 0.35rem;
        align-self: stretch;
        border-right: 1px solid var(--ink-6);
    }
    .qs-dots span {
        display: block;
        width: 0.6rem;
        height: 0.6rem;
        border-radius: 50%;
        border: 1px solid var(--ink-5);
        background-color: transparent;
        box-sizing: border-box;
    }
    .qs-dots span:nth-child(1) {
        background-color: var(--accent);
        border-color: var(--accent);
    }
    .qs-tab {
        font-family:
            'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 0.8125rem;
        background: none;
        border: none;
        padding: 0.85rem 1rem;
        color: var(--ink-4);
        cursor: pointer;
        position: relative;
        transition: color 0.15s ease;
        white-space: nowrap;
    }
    .qs-tab:hover { color: var(--ink-2); }
    .qs-tab.active { color: var(--ink-1); }
    .qs-tab.active::after {
        content: '';
        position: absolute;
        left: 0.5rem;
        right: 0.5rem;
        bottom: -1px;
        height: 2px;
        background-color: var(--accent);
    }

    .qs-pane { display: none; }
    .qs-pane.active { display: block; }

    .qs-install {
        position: relative;
        font-family:
            'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 0.825rem;
        padding: 1rem 3rem 1rem 1.25rem;
        color: var(--ink-2);
        background-color: var(--surface-0);
        border-bottom: 1px solid var(--ink-6);
        white-space: pre-wrap;
        overflow-wrap: anywhere;
    }
    .qs-install .qs-prompt {
        color: var(--ink-4);
        margin-right: 0.6rem;
        user-select: none;
    }
    .qs-copy {
        position: absolute;
        top: 0.5rem;
        right: 0.5rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 1.75rem;
        height: 1.75rem;
        padding: 0;
        background: none;
        border: 1px solid transparent;
        border-radius: 0.375rem;
        color: var(--ink-4);
        cursor: pointer;
        transition: color 0.12s ease, background-color 0.12s ease, border-color 0.12s ease;
    }
    .qs-copy:hover {
        color: var(--ink-2);
        background-color: var(--surface-1);
        border-color: var(--ink-6);
    }
    .qs-copy-icon-check { display: none; }
    .qs-copy.copied .qs-copy-icon-clip { display: none; }
    .qs-copy.copied .qs-copy-icon-check { display: inline-block; color: var(--accent); }

    .qs-code {
        margin: 0;
        padding: 1.25rem;
        font-family:
            'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 0.825rem;
        line-height: 1.65;
        color: var(--ink-1);
        background-color: #f8f6f3;
        overflow-x: auto;
    }
    .qs-code code { background: none; padding: 0; font-family: inherit; }
    /* Hand-rolled monochrome highlighter (see src/lib/highlight.ts): only
       language keywords are colored, in the page accent. Everything else
       inherits the default ink color for a single-hue look. The :global() is
       required because `set:html` injects spans that don't carry Astro's
       scoped-component class, so the selector must escape the component scope. */
    .qs-code :global(.kw) { color: var(--accent); }

    /* ---------- Closing CTA ---------- */

    .closing {
        position: relative;
        padding: 6rem 0 7rem;
        text-align: center;
        border-top: 1px solid var(--sl-color-hairline, rgba(15, 22, 32, 0.08));
        margin-top: 4rem;
        isolation: isolate;
    }
    /* Doric columns flanking the closing CTA. Same ambient treatment as the
       hero atlas — slight transparency + minimal blur so the figures read as
       background art rather than foreground content. Right column mirrored
       below via scaleX(-1). */
    .closing-colonnade {
        position: absolute;
        top: 50%;
        display: flex;
        align-items: end;
        pointer-events: none;
        z-index: 0;
    }
    .closing-colonnade img {
        /* Fixed height so the columns stay visually stable as the viewport
           narrows — the colonnade is hidden below 767px anyway, so there's no
           tight range that needs adaptive scaling. */
        height: 18rem;
        width: auto;
        opacity: 0.48;
        filter: blur(0.5px);
    }
    /* Spacing between the two columns within a pair. Negative pulls them
       together (their raster has whitespace padding); positive pushes them
       apart. Tune to taste. */
    .closing-colonnade img + img {
        margin-inline-start: -8rem;
    }
    /* Push each pair outward into main's inline padding so the gap between
       the left pair and right pair (around the text) opens up. */
    .closing-colonnade-left {
        left: -2rem;
        transform: translateY(-50%);
    }
    .closing-colonnade-right {
        right: -2rem;
        transform: translateY(-50%) scaleX(-1);
    }
    /* Constrain the text column so it sits clear of the colonnade with
       comfortable breathing room on either side. */
    .closing-text {
        position: relative;
        z-index: 1;
        max-width: 30rem;
        margin-inline: auto;
    }
    /* Same "vellum" trick used for the editorial prose: a translucent
       surface-0 wash + backdrop-blur with a feathered radial mask sits behind
       the text, so when the colonnade visually overlaps the headline the text
       still reads cleanly. No visible card edges. */
    .closing-text::before {
        content: "";
        position: absolute;
        inset: -1.5rem -2rem;
        background-color: rgba(246, 247, 249, 0.55);
        backdrop-filter: blur(18px) saturate(140%);
        -webkit-backdrop-filter: blur(18px) saturate(140%);
        -webkit-mask-image: radial-gradient(ellipse 75% 85% at center, black 45%, transparent 100%);
        mask-image: radial-gradient(ellipse 75% 85% at center, black 45%, transparent 100%);
        z-index: -1;
        pointer-events: none;
    }
    @media (max-width: 767px) {
        .closing-colonnade { display: none; }
    }
    .closing-headline {
        font-family:
            'Marcellus', ui-serif, Georgia, 'Times New Roman', serif;
        font-weight: 400;
        font-size: clamp(1.75rem, 3.5vw, 2.5rem);
        line-height: 1.15;
        letter-spacing: -0.005em;
        color: var(--ink-1);
        margin: 0;
    }
    .closing-sub {
        max-width: 36rem;
        margin: 1rem auto 0;
        font-size: 1rem;
        line-height: 1.6;
        color: var(--ink-3);
    }
    .closing-ctas {
        margin-top: 2rem;
        display: flex;
        justify-content: center;
        gap: 0.75rem;
        flex-wrap: wrap;
    }

    /* ---------- Footer (Commonhaus block preserved) ---------- */

    .footer {
        width: 100%;
        border-top: 1px solid var(--ink-6);
        /* Match main + header so the footer's inner edges line up at all widths. */
        padding: 1.25rem clamp(1.5rem, 4vw, 4rem);
        background-color: var(--surface-0);
        margin-top: auto;
        box-sizing: border-box;
    }
    .footer-content {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        align-items: center;
        max-width: 80rem;
        margin: 0 auto;
    }
    .footer-icons {
        display: flex;
        gap: 1rem;
        align-items: center;
        order: 1;
    }
    .copyright-wrapper {
        font-size: 0.7rem;
        font-family:
            'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
        order: 2;
        text-align: center;
        line-height: 1.5;
        color: var(--ink-4);
    }
    .copyright-wrapper a { color: var(--ink-4); }
    .copyright-wrapper a:hover { color: var(--ink-2); }

    @media (min-width: 50rem) {
        .footer { padding: 1.25rem 2rem; }
        .footer-content {
            flex-direction: row;
            justify-content: space-between;
            align-items: center;
        }
        .footer-icons { order: 2; }
        .copyright-wrapper { order: 1; text-align: left; }
    }
</style>

<script>
    // Astro <script> blocks are emitted as type=module and defer, so by the time
    // they execute, DOMContentLoaded may already have fired — guard against that.
    const onReady = (fn: () => void) => {
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', fn);
        } else {
            fn();
        }
    };
    onReady(() => {
        // Feature plate tabs
        const featurePlate = document.querySelector('[data-feature-plate]');
        if (featurePlate) {
            const featureTabs = Array.from(featurePlate.querySelectorAll<HTMLButtonElement>('[data-feature-tab]'));
            const featurePanels = Array.from(featurePlate.querySelectorAll<HTMLElement>('[data-feature-panel]'));
            const featureCopies = Array.from(featurePlate.querySelectorAll<HTMLElement>('[data-feature-copy]'));
            const activateFeature = (id: string, focus = false) => {
                featureTabs.forEach((tab) => {
                    const matches = tab.dataset.featureTab === id;
                    tab.classList.toggle('active', matches);
                    tab.setAttribute('aria-selected', matches ? 'true' : 'false');
                    if (matches && focus) tab.focus();
                });
                featurePanels.forEach((panel) => {
                    panel.classList.toggle('active', panel.dataset.featurePanel === id);
                });
                featureCopies.forEach((copy) => {
                    copy.classList.toggle('active', copy.dataset.featureCopy === id);
                });
            };

            featureTabs.forEach((tab, index) => {
                tab.addEventListener('click', () => {
                    const id = tab.dataset.featureTab;
                    if (id) activateFeature(id);
                });
                tab.addEventListener('keydown', (event) => {
                    if (event.key !== 'ArrowLeft' && event.key !== 'ArrowRight') return;
                    event.preventDefault();
                    const offset = event.key === 'ArrowRight' ? 1 : -1;
                    const next = featureTabs[(index + offset + featureTabs.length) % featureTabs.length];
                    const id = next?.dataset.featureTab;
                    if (id) activateFeature(id, true);
                });
            });
        }

        // Quickstart language tabs
        const tabs = document.querySelectorAll('.qs-tab');
        const panes = document.querySelectorAll('.qs-pane');
        tabs.forEach((tab) => {
            tab.addEventListener('click', () => {
                const id = tab.getAttribute('data-tab');
                tabs.forEach((t) => {
                    t.classList.remove('active');
                    t.setAttribute('aria-selected', 'false');
                });
                tab.classList.add('active');
                tab.setAttribute('aria-selected', 'true');
                panes.forEach((p) => {
                    if (p instanceof HTMLElement) {
                        const matches = p.getAttribute('data-content') === id;
                        p.classList.toggle('active', matches);
                    }
                });
            });
        });

        // Mobile menu
        const mobileMenuToggle = document.getElementById('mobile-menu-toggle');
        const mobileMenu = document.getElementById('mobile-menu');
        if (mobileMenuToggle && mobileMenu) {
            mobileMenuToggle.addEventListener('click', () => {
                const isOpen = mobileMenuToggle.getAttribute('aria-expanded') === 'true';
                mobileMenuToggle.setAttribute('aria-expanded', (!isOpen).toString());
                mobileMenu.classList.toggle('open', !isOpen);
            });
            mobileMenu.querySelectorAll('.mobile-menu-link').forEach((link) => {
                link.addEventListener('click', () => {
                    mobileMenuToggle.setAttribute('aria-expanded', 'false');
                    mobileMenu.classList.remove('open');
                });
            });
        }

        // Copy-to-clipboard buttons on each quickstart install row
        document.querySelectorAll<HTMLButtonElement>('.qs-copy').forEach((btn) => {
            btn.addEventListener('click', async () => {
                const text = btn.getAttribute('data-copy') ?? '';
                try {
                    await navigator.clipboard.writeText(text);
                } catch {
                    // Older browsers / non-secure contexts: fall back to execCommand.
                    const ta = document.createElement('textarea');
                    ta.value = text;
                    ta.style.position = 'fixed';
                    ta.style.opacity = '0';
                    document.body.appendChild(ta);
                    ta.select();
                    document.execCommand('copy');
                    document.body.removeChild(ta);
                }
                btn.classList.add('copied');
                setTimeout(() => btn.classList.remove('copied'), 1500);
            });
        });

        // GitHub stars are fetched at build time (src/lib/github-stars.ts) and
        // rendered statically — no runtime fetch, no layout jitter on load.
    });
</script>
