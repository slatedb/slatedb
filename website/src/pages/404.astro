---
import SocialIcons from '../components/SocialIcons.astro';
import ThemeProvider from '../components/ThemeProvider.astro';
import barsIcon from '@hackernoon/pixel-icon-library/icons/SVG/regular/bars.svg?raw';
import timesIcon from '@hackernoon/pixel-icon-library/icons/SVG/regular/times.svg?raw';
import { getStarsLabel } from '../lib/github-stars';
import Analytics from '../components/Analytics.astro';

const starsLabel = await getStarsLabel();
---

<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>404 — page not found | SlateDB</title>
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="description" content="The page you're looking for isn't here." />
        <meta name="robots" content="noindex" />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            rel="stylesheet"
            href="https://fonts.googleapis.com/css2?family=Marcellus&family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,500;0,8..60,600;0,8..60,700;1,8..60,400;1,8..60,500;1,8..60,600;1,8..60,700&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
        />
        <Analytics />
    </head>
    <body>
        <ThemeProvider />
        <div class="page">
            <header class="header">
                <div class="header-content">
                    <a href="/" class="site-title">
                        <img src="/img/logo-full.svg" alt="SlateDB" />
                    </a>
                    <div class="right-group">
                        <nav class="header-links">
                            <a href="/docs/get-started/introduction/" class="header-link">docs</a>
                            <a href="https://discord.gg/mHYmGy5MgA" target="_blank" rel="noopener noreferrer" class="header-link">discord</a>
                            <a href="https://github.com/slatedb/slatedb" target="_blank" rel="noopener noreferrer" class="header-link" id="github-link">github <span class="star-count"><span class="star-icon">★</span>{starsLabel}</span></a>
                        </nav>
                        <button class="mobile-menu-toggle" id="mobile-menu-toggle" aria-label="Toggle menu" aria-expanded="false">
                            <span class="menu-icon menu-icon-bars" set:html={barsIcon}></span>
                            <span class="menu-icon menu-icon-times" set:html={timesIcon}></span>
                        </button>
                    </div>
                    <div class="mobile-menu" id="mobile-menu">
                        <a href="/docs/get-started/introduction/" class="mobile-menu-link">docs</a>
                        <a href="https://discord.gg/mHYmGy5MgA" target="_blank" rel="noopener noreferrer" class="mobile-menu-link">discord</a>
                        <a href="https://github.com/slatedb/slatedb" target="_blank" rel="noopener noreferrer" class="mobile-menu-link" id="mobile-github-link">github <span class="star-count"><span class="star-icon">★</span>{starsLabel}</span></a>
                    </div>
                </div>
            </header>

            <main>
                <section class="hero">
                    <div class="hero-art" aria-hidden="true">
                        <img src="/img/slatedb-sisyphus.png" alt="" width="1122" height="1402" loading="eager" decoding="async" />
                    </div>
                    <div class="hero-text">
                        <div class="error-num">404</div>
                        <p class="hero-sub">
                            The page you're looking for may never exist.
                        </p>
                        <div class="hero-ctas">
                            <a class="cta cta-primary" href="/">Home</a>
                            <a class="cta cta-secondary" href="/docs/get-started/introduction/">
                                <span>Docs</span>
                            </a>
                        </div>
                    </div>
                </section>
            </main>

            <footer class="footer">
                <div class="footer-content">
                    <div class="footer-icons">
                        <SocialIcons />
                    </div>
                    <div class="copyright-wrapper">
                        <p>
                            <img src="https://raw.githubusercontent.com/commonhaus/artwork/main/foundation/brand/svg/CF_logo_horizontal_single_default.svg" height="20" alt="Commonhaus Foundation"/><br />
                            Copyright © <a href="https://slatedb.io">SlateDB</a>. All rights reserved. For details on our trademarks, please visit our <a href="https://www.commonhaus.org/policies/trademark-policy/">Trademark Policy</a> and <a href="https://www.commonhaus.org/trademarks/">Trademark List</a>.<br/>
                            Trademarks of third parties are owned by their respective holders and their mention here does not suggest any endorsement or association.
                        </p>
                    </div>
                </div>
            </footer>
        </div>
    </body>
</html>

<style>
    /* Design tokens — duplicated from index.astro so the 404 stays coherent
       even if it loads standalone (no starlight customCss in scope here). */
    :root {
        --ink-1: #0f1620;
        --ink-2: #1f2a37;
        --ink-3: #3d4856;
        --ink-4: #5e6878;
        --ink-5: #8b94a3;
        --ink-6: #c8cdd5;
        --ink-7: #dfe2e8;
        --surface-0: #f6f7f9;
        --surface-1: #ffffff;
        --surface-2: #eef0f3;
        --surface-3: #e2e6eb;
        --accent-high: #7a3e22;
        --accent: #b26844;
        --accent-low: #f3e3d8;
    }

    html, body {
        margin: 0;
        padding: 0;
        background-color: var(--surface-0);
        color: var(--ink-2);
        font-family:
            'Inter', ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
            'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        text-rendering: optimizeLegibility;
    }
    body { min-height: 100vh; }

    .page {
        display: flex;
        flex-direction: column;
        min-height: 100vh;
        position: relative;
        /* Mirror of the index's top-right corner glow — anchored at the
           top-left here, tracking the Thinker's position. Same intensity
           so the two pages feel like one set. */
        background:
            radial-gradient(circle at 0% 0%, rgba(178, 104, 68, 0.08), transparent 28%),
            var(--surface-0);
        isolation: isolate;
    }

    /* ---------- Header (mirrors index.astro) ---------- */

    .header {
        position: sticky;
        top: 0;
        z-index: 100;
        background-color: rgba(246, 247, 249, 0.45);
        backdrop-filter: saturate(180%) blur(16px);
        -webkit-backdrop-filter: saturate(180%) blur(16px);
        padding: 1rem clamp(1.5rem, 4vw, 4rem);
    }
    .header-content {
        display: flex;
        align-items: center;
        justify-content: space-between;
        max-width: 72rem;
        margin: 0 auto;
        position: relative;
    }
    .site-title { display: inline-flex; align-items: center; }
    .site-title img { height: 1.6rem; width: auto; }
    .right-group { display: flex; align-items: center; gap: 1rem; }
    .header-links { display: flex; gap: 1.5rem; align-items: center; }
    .header-link {
        font-size: 0.8125rem;
        font-family:
            'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
        color: var(--ink-2);
        text-decoration: none;
        transition: color 0.15s ease;
        display: inline-flex;
        align-items: center;
    }
    .header-link:hover { color: var(--accent); }
    .header-link .star-count,
    .mobile-menu-link .star-count {
        display: inline-flex;
        align-items: center;
        gap: 0.2rem;
        margin-left: 0.55rem;
        padding: 0.12rem 0.45rem;
        background-color: var(--surface-1);
        border: 1px solid var(--ink-6);
        border-radius: 0;
        color: var(--ink-2);
        font-size: 0.72rem;
        font-weight: 500;
        line-height: 1;
        transition: border-color 0.15s ease, background-color 0.15s ease;
    }
    .header-link:hover .star-count,
    .mobile-menu-link:hover .star-count { border-color: var(--ink-4); }
    .header-link .star-count .star-icon,
    .mobile-menu-link .star-count .star-icon {
        color: var(--accent);
        font-size: 0.8rem;
        line-height: 1;
    }
    .mobile-menu-toggle {
        display: none;
        background: none;
        border: none;
        cursor: pointer;
        padding: 0.5rem;
        margin: -0.5rem;
        position: relative;
        width: 2rem;
        height: 2rem;
        color: var(--ink-2);
    }
    .menu-icon {
        position: absolute;
        inset: 0.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: opacity 0.15s ease;
    }
    .menu-icon svg { width: 1rem; height: 1rem; fill: currentColor; }
    .menu-icon-times { opacity: 0; }
    .mobile-menu-toggle[aria-expanded='true'] .menu-icon-bars { opacity: 0; }
    .mobile-menu-toggle[aria-expanded='true'] .menu-icon-times { opacity: 1; }
    .mobile-menu {
        display: none;
        flex-direction: column;
        gap: 0.5rem;
        padding: 1rem 1.5rem;
        background-color: var(--surface-0);
        border-top: 1px solid var(--ink-6);
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
    }
    .mobile-menu.open { display: flex; }
    .mobile-menu-link {
        font-family:
            'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 0.875rem;
        color: var(--ink-2);
        text-decoration: none;
        padding: 0.5rem 0;
    }
    @media (max-width: 768px) {
        .header-links { display: none; }
        .mobile-menu-toggle { display: flex; }
    }

    /* ---------- 404 hero ---------- */

    main {
        max-width: 72rem;
        margin: 0 auto;
        padding: 0 clamp(1.5rem, 4vw, 4rem);
        width: 100%;
        box-sizing: border-box;
        flex: 1;
        display: flex;
    }

    .hero {
        padding: 5rem 0 4rem;
        position: relative;
        isolation: isolate;
        flex: 1;
        display: flex;
        align-items: center;
    }
    /* Same fading grid as the index hero — but tighter, since the 404 is
       one section instead of a full page. Stops at the bottom of the hero. */
    .hero::before {
        content: "";
        position: absolute;
        inset: 0;
        pointer-events: none;
        opacity: 0.18;
        background-image:
            linear-gradient(rgba(80, 70, 55, 0.16) 1px, transparent 1px),
            linear-gradient(90deg, rgba(80, 70, 55, 0.16) 1px, transparent 1px);
        background-size: 72px 72px;
        /* Mask centered around the Thinker on the left to amplify the
           halo-of-lines effect already in the artwork. */
        -webkit-mask-image: radial-gradient(ellipse 65% 70% at 30% 50%, black 0%, transparent 100%);
        mask-image: radial-gradient(ellipse 65% 70% at 30% 50%, black 0%, transparent 100%);
        z-index: -1;
    }

    /* Mirror of index hero: art on the LEFT, text on the RIGHT. The
       Thinker's gaze and forward lean point inward toward the headline. */
    .hero-art {
        position: absolute;
        top: 50%;
        left: -3rem;
        transform: translateY(-50%);
        width: clamp(28rem, 42vw, 40rem);
        max-width: 55%;
        pointer-events: none;
        z-index: 0;
        opacity: 0.8;
        filter: blur(0.25px);
    }
    .hero-art img {
        width: 100%;
        height: auto;
        display: block;
        opacity: 0.6;
    }
    .hero-text {
        max-width: 32rem;
        margin-left: auto;
        position: relative;
        z-index: 1;
    }
    @media (max-width: 767px) {
        .hero { padding: 4rem 0 3rem; }
        .hero-art { display: none; }
        .hero-text { margin-left: 0; max-width: 100%; }
    }

    /* Big inscribed numeral — the chapter mark of this dead-end page.
       Marcellus, sized like a stele heading, in terracotta. */
    .error-num {
        font-family:
            'Marcellus', ui-serif, Georgia, 'Times New Roman', serif;
        font-size: clamp(3rem, 7vw, 5rem);
        line-height: 0.95;
        letter-spacing: 0.04em;
        color: var(--accent);
        margin: 0 0 1rem;
    }

    .hero-headline {
        font-family:
            'Marcellus', ui-serif, Georgia, 'Times New Roman', serif;
        font-weight: 400;
        font-size: clamp(2rem, 4.5vw, 3.25rem);
        line-height: 1.1;
        letter-spacing: -0.005em;
        color: var(--ink-1);
        margin: 0;
    }
    .hero-headline em {
        font-style: normal;
        color: var(--accent-high);
    }

    .hero-sub {
        margin: 1.5rem 0 0;
        font-size: 1.0625rem;
        line-height: 1.6;
        color: var(--ink-3);
        max-width: 32rem;
    }
    @media (max-width: 1199px) {
        .hero-sub { max-width: 24rem; }
    }
    @media (max-width: 991px) {
        .hero-sub { max-width: 20rem; }
    }

    .hero-ctas {
        display: flex;
        gap: 0.75rem;
        margin-top: 2rem;
        flex-wrap: wrap;
    }
    .cta {
        font-family:
            'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 0.8125rem;
        padding: 0.7rem 1.1rem;
        border-radius: 0.5rem;
        text-decoration: none;
        transition: all 0.15s ease;
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
    }
    .cta-primary {
        background-color: var(--ink-1);
        color: var(--surface-0);
    }
    .cta-primary:hover { background-color: var(--accent-high); }
    .cta-secondary {
        background-color: transparent;
        color: var(--ink-2);
        border: 1px solid var(--ink-6);
    }
    .cta-secondary:hover {
        border-color: var(--ink-4);
        color: var(--ink-1);
    }

    /* ---------- Footer (mirrors index.astro) ---------- */

    .footer {
        width: 100%;
        border-top: 1px solid var(--ink-6);
        padding: 1.25rem clamp(1.5rem, 4vw, 4rem);
        background-color: var(--surface-0);
        margin-top: auto;
        box-sizing: border-box;
    }
    .footer-content {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        align-items: center;
        max-width: 72rem;
        margin: 0 auto;
    }
    .footer-icons {
        display: flex;
        gap: 1rem;
        align-items: center;
        order: 1;
    }
    .copyright-wrapper {
        font-size: 0.7rem;
        font-family:
            'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
        order: 2;
        text-align: center;
        line-height: 1.5;
        color: var(--ink-4);
    }
    .copyright-wrapper a { color: var(--ink-4); }
    .copyright-wrapper a:hover { color: var(--ink-2); }

    @media (min-width: 50rem) {
        .footer { padding: 1.25rem 2rem; }
        .footer-content {
            flex-direction: row;
            justify-content: space-between;
            align-items: center;
        }
        .footer-icons { order: 2; }
        .copyright-wrapper { order: 1; text-align: left; }
    }
</style>

<script>
    const onReady = (fn: () => void) => {
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', fn);
        } else {
            fn();
        }
    };
    onReady(() => {
        const mobileMenuToggle = document.getElementById('mobile-menu-toggle');
        const mobileMenu = document.getElementById('mobile-menu');
        if (mobileMenuToggle && mobileMenu) {
            mobileMenuToggle.addEventListener('click', () => {
                const isOpen = mobileMenuToggle.getAttribute('aria-expanded') === 'true';
                mobileMenuToggle.setAttribute('aria-expanded', (!isOpen).toString());
                mobileMenu.classList.toggle('open', !isOpen);
            });
            mobileMenu.querySelectorAll('.mobile-menu-link').forEach((link) => {
                link.addEventListener('click', () => {
                    mobileMenuToggle.setAttribute('aria-expanded', 'false');
                    mobileMenu.classList.remove('open');
                });
            });
        }
    });
</script>
